{
  "name": "codevolley",
  "version": "0.0.0",
  "description": "Local MCP server + web UI for collaborative, thread-based code review between Claude and a developer.",
  "private": true,
  "type": "module",
  "bin": {
    "codevolley": "./dist/daemon/cli.js",
    "codevolley-mcp": "./dist/adapter/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:web",
    "build:web": "cd web && npm run build",
    "dev:daemon": "tsx watch src/daemon/cli.ts",
    "dev:adapter": "tsx src/adapter/index.ts",
    "serve": "node dist/daemon/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}
